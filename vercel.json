{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "app/api/**/*": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "required",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "required",
    "DATABASE_URL": "required",
    "DIRECT_URL": "required",
    "RESEND_API_KEY": "required",
    "NEXT_PUBLIC_SITE_URL": "required"
  },
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "regions": ["iad1"]
}